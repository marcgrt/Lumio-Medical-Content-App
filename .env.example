# ============================================================
# Lumio Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ============================================================

# ---------- LLM API Keys (Free Tier) ----------
GROQ_API_KEY=gsk_...                    # https://console.groq.com — Primary für Summaries
GEMINI_API_KEY=AIza...                  # https://aistudio.google.com — Prefilter + Scoring
MISTRAL_API_KEY=...                     # https://console.mistral.ai — Fallback

# Optional: Anthropic (Legacy-Fallback, kostenpflichtig)
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- SMTP (Digest-Email + Alerts) ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=lumio@example.com
ALERT_EMAIL=admin@example.com

# ---------- Digest ----------
DIGEST_EMAIL=redaktion@example.com

# ---------- API (für n8n / externe Trigger) ----------
API_TOKEN=your-secret-token-here

# ---------- Domain (für SSL-Zertifikat) ----------
DOMAIN=lumio.example.com
CERT_EMAIL=admin@example.com
